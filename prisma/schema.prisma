generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id                    String    @id @default(cuid())
  name                  String
  phoneNumber           String    @unique
  planType              String
  region                String
  preferredLanguage     String    @default("English")
  totalComplaints       Int       @default(0)
  lastComplaintCategory String?
  churnRisk             Float     @default(0.0)
  retentionEligible     Boolean   @default(true)
  vipStatus             Boolean   @default(false)
  billingIssueCount     Int       @default(0)
  networkIssueCount     Int       @default(0)
  repeatedIssueCount    Int       @default(0)
  escalationCount       Int       @default(0)
  lastSentiment         String    @default("Neutral")
  createdAt             DateTime  @default(now())
  sessions              Session[]
}

model Session {
  id             String             @id @default(cuid())
  customerId     String?
  channelType    String
  status         String             @default("active")
  startedAt      DateTime           @default(now())
  endedAt        DateTime?
  summary        CallSummary?
  turns          ConversationTurn[]
  extractedFacts ExtractedFact[]
  memoryItems    MemoryItem[]
  isEscalated    Boolean            @default(false)
  isRiskFlagged  Boolean            @default(false)
  riskScore      Float              @default(0.0)
  supervisorNote String?
  metadata       String?            // Generic JSON storage for demo/eval
  customer       Customer?          @relation(fields: [customerId], references: [id])
}

model ConversationTurn {
  id           String          @id @default(cuid())
  sessionId    String
  turnIndex    Int
  customerText String
  agentReply   String?
  sourceType   String
  createdAt    DateTime        @default(now())
  session      Session         @relation(fields: [sessionId], references: [id])
  insight      CopilotInsight?
  facts        ExtractedFact[]
}

model CopilotInsight {
  id                    String           @id @default(cuid())
  turnId                String           @unique
  intent                String
  sentiment             String
  riskLevel             String
  nextBestAction        String
  escalationRecommended Boolean          @default(false)
  escalationReason      String?
  confidenceScore       Float            @default(1.0)
  policyBoundaryStatus  String?
  policyReason          String?
  policyEscalationTriggered Boolean?     @default(false)
  createdAt             DateTime         @default(now())
  turn                  ConversationTurn @relation(fields: [turnId], references: [id])
}

model ExtractedFact {
  id        String            @id @default(cuid())
  sessionId String
  turnId    String?
  factKey   String
  factValue String
  factType  String
  createdAt DateTime          @default(now())
  turn      ConversationTurn? @relation(fields: [turnId], references: [id])
  session   Session           @relation(fields: [sessionId], references: [id])
}

model MemoryItem {
  id         String   @id @default(cuid())
  sessionId  String
  memoryText String
  memoryType String
  importance Int      @default(1)
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id])
}

model CallSummary {
  id               String   @id @default(cuid())
  sessionId        String   @unique
  overallIntent    String
  finalSentiment   String
  overallRisk      String
  resolutionStatus String
  summaryText      String
  structuredSummary String?         // JSON: case identity, intent, facts, policy notes, recommendations
  followUpAction   String?
  commitmentsMade  String?          // JSON: allowed vs blocked
  createdAt        DateTime @default(now())
  session          Session  @relation(fields: [sessionId], references: [id])
}

model SimulationScenario {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String
  scriptJson  String
  difficulty  String
  createdAt   DateTime @default(now())
}
